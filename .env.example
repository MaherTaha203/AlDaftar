# Supabase connection.
# Copy this file to `.env.local` and fill the values from the Supabase
# project dashboard. Never commit populated credentials.

# Project URL + anon (publishable) key — used by the browser client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER-ONLY (never NEXT_PUBLIC, never shipped to the
# browser). Used exclusively by migration/verification scripts
# (scripts/verify-supabase.mjs and the schema-phase tooling).
SUPABASE_SERVICE_ROLE_KEY=
